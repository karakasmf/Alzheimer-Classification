# Model checkpoints (large binary files — download separately)
# =============================================================================
benchmark/lead/checkpoints/
benchmark/LaBraM/checkpoints/

# =============================================================================
# IDE / editor
# =============================================================================
.idea/
.vscode/
*.code-workspace

# =============================================================================
# OS files
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Jupyter notebooks checkpoints
# =============================================================================
.ipynb_checkpoints/

# =============================================================================
# Logs & temp files
# =============================================================================
*.log
*.tmp
*.bak

# =============================================================================
# Build / dist (if ever packaged)
# =============================================================================
dist/
build/
*.egg-info/
